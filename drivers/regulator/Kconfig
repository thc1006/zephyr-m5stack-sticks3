config REGULATOR_M5PM1
	bool "M5Stack M5PM1 PMIC regulator"
	default y
	depends on DT_HAS_M5STACK_M5PM1_L3B_REGULATOR_ENABLED
	select I2C
	select REGULATOR
	help
	  M5Stack M5PM1 PMIC single-rail (GPIO-switched) regulator driver.
	  Drives an M5PM1 GPIO high to enable a peripheral power domain (e.g.
	  GPIO2 = the "L3B" rail that powers the StickS3 LCD/MIC/SPK).

if REGULATOR_M5PM1

config REGULATOR_M5PM1_INIT_PRIORITY
	int "M5PM1 regulator init priority"
	default 75
	help
	  Device init priority for the M5PM1 regulator. Must be greater than
	  CONFIG_I2C_INIT_PRIORITY and less than the display init priority so the
	  rail is powered before the display is reset/initialized.

endif # REGULATOR_M5PM1

config EMUL_M5PM1
	bool "M5Stack M5PM1 PMIC emulator"
	default y
	depends on EMUL
	depends on DT_HAS_M5STACK_M5PM1_L3B_REGULATOR_ENABLED
	help
	  I2C emulator for the M5PM1 PMIC, for native_sim driver unit tests.
