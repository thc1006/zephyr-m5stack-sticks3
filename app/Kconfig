mainmenu "M5StickS3 validation app"

config APP_DISPLAY_DEMO
	bool "Diagnostics page colour-cycle + backlight blink"
	default y
	help
	  When enabled, the diagnostics page (PAGE_DIAG) cycles the LCD through
	  R/G/B/W fills and periodically blinks the backlight via the regulator
	  API, to exercise the display and the M5PM1 power-rail control on
	  hardware.

	  Disable it (for example -DCONFIG_APP_DISPLAY_DEMO=n) for a quiet
	  diagnostics page (static black fill); the other pages are unaffected.

config APP_BLE
	bool "BLE advertising + GATT telemetry"
	default n
	help
	  When enabled, the app brings up the Bluetooth LE controller and starts
	  connectable + scannable advertising that carries the device name and a
	  manufacturer-specific telemetry payload (uptime, battery mV, accel mg).
	  It also exposes a custom 128-bit GATT service with a READ + NOTIFY
	  telemetry characteristic, and adds a BLE status page to the UI.

	  This pulls in the full Bluetooth host + the Espressif controller HAL,
	  so it requires the binary blob: run `west blobs fetch hal_espressif`
	  before building. It is off by default so the standard build stays
	  blob-free. Enable it via -DEXTRA_CONF_FILE=overlay-ble.conf, which also
	  turns on CONFIG_BT and the peripheral role.

config APP_AUDIO
	bool "ES8311 audio (440 Hz beep)"
	default n
	help
	  When enabled, the app brings up the on-board ES8311 codec on I2S0 and
	  adds an AUDIO page that plays a short 440 Hz beep when the page is
	  entered. The AW8737 speaker amplifier (M5PM1 GPIO3) is enabled only for
	  the duration of the beep.

	  This needs CONFIG_AUDIO / CONFIG_AUDIO_CODEC (ES8311) and CONFIG_I2S
	  (esp32-i2s + DMA). It is off by default so the standard build is
	  unchanged; enable it via -DEXTRA_CONF_FILE=overlay-audio.conf, which
	  turns on the codec, I2S, and DMA Kconfigs.

config APP_AUDIO_REC_SECONDS
	int "Record->playback clip length (seconds)"
	depends on APP_AUDIO
	default 5
	range 1 8
	help
	  Length of the mic clip recorded on the REC page, in seconds (issue #14),
	  at 16 kHz / 16-bit mono. Each second uses 32 KB of internal SRAM (dram0):
	  the default 5 s = 156 KB, which fits with margin (see
	  docs/14_RECORD_PLAYBACK_DESIGN.md baseline).

config APP_AUDIO_REC_GAIN_Q8
	int "Record->playback digital gain (Q8; 256 = 1.0x)"
	depends on APP_AUDIO
	default 2048
	range 256 8192
	help
	  Fixed-point gain applied to the recorded clip on playback so a quiet mic
	  capture is audible on the small speaker (256 = unity, 1024 = 4.0x). The
	  result saturates at the int16 range, so over-gain clips instead of
	  wrapping. Tune for clear, intelligible replay (requirement QR-1).

config APP_IR
	bool "IR transmit + receive (NEC)"
	default n
	help
	  When enabled, the app brings up consumer-IR (NEC) on the StickS3 IR LED
	  (G46) and IR receiver (G42), and adds an IR page that transmits a test NEC
	  frame on entry and shows the last decoded address/command.

	  Zephyr 4.4 has no ESP32 RMT driver, so IR uses stock PWM peripherals: the
	  LEDC PWM generates the ~38 kHz carrier (TX) and MCPWM input capture reads
	  the receiver (RX); the NEC envelope and decoding live in app/src/nec.c. It
	  is off by default so the standard build is unchanged; enable it via
	  -DEXTRA_CONF_FILE=overlay-ir.conf, which turns on CONFIG_PWM and
	  CONFIG_PWM_CAPTURE. Uses no binary blobs.

config APP_WIFI
	bool "Wi-Fi station (scan + connect)"
	default n
	depends on !APP_BLE
	help
	  When enabled, the app brings up the ESP32-S3 native Wi-Fi in station
	  mode and adds a Wi-Fi page that scans for nearby APs (SSID, signal bars,
	  security) and, with credentials configured, connects and obtains a DHCP
	  lease. The pure scan/connect/config logic lives in app/src/wifi.c
	  (unit-tested on native_sim); the wifi_mgmt/net_mgmt glue is in
	  app/src/wifi_glue.c.

	  This pulls in the full Wi-Fi driver, networking stack, and the driver's
	  bundled (ESP-IDF) supplicant, so it needs the Espressif HAL blob (west
	  blobs fetch hal_espressif). It is mutually exclusive with CONFIG_APP_BLE
	  because Wi-Fi + BLE coexistence is not a validated Zephyr configuration on
	  the ESP32-S3. Enable it via -DEXTRA_CONF_FILE=overlay-wifi.conf together with
	  -DEXTRA_DTC_OVERLAY_FILE=overlay-wifi.overlay (scripts/build_wifi.sh),
	  which also enables the &wifi node and the Wi-Fi/net Kconfigs.

config APP_WIFI_SSID
	string "Wi-Fi SSID to auto-connect to"
	depends on APP_WIFI
	default ""
	help
	  SSID the station auto-connects to a few seconds after boot. Leave it
	  empty (the default) to scan only, with no connection attempt. Provide a
	  real value from a LOCAL, untracked overlay (scripts/build_wifi.sh picks up
	  app/wifi-creds.local.conf if present) so credentials are never committed.

config APP_WIFI_PSK
	string "Wi-Fi WPA2 passphrase for CONFIG_APP_WIFI_SSID"
	depends on APP_WIFI
	default ""
	help
	  WPA2-PSK passphrase (8..63 characters) for CONFIG_APP_WIFI_SSID. An empty
	  value (the default) treats the configured SSID as an open network. Keep
	  this in a LOCAL, untracked overlay; never commit credentials.

source "Kconfig.zephyr"
