 *
 * M5Stack StickS3 (ESP32-S3-PICO-1-N8R8) board devicetree.
 * Pin map source: M5Stack official StickS3 PinMap. See
 * docs/00_RESEARCH_SNAPSHOT.md and docs/09_SOURCES.md.
 */
/dts-v1/;

#include <espressif/esp32s3/esp32s3_pico_n8r8.dtsi>
#include "m5stack_sticks3-pinctrl.dtsi"
#include <zephyr/dt-bindings/adc/adc.h>
#include <zephyr/dt-bindings/input/input-event-codes.h>
#include <espressif/partitions_0x0_amp.dtsi>

/ {
	model = "M5Stack StickS3 PROCPU";
	compatible = "m5stack,sticks3";

	chosen {
		zephyr,sram = &sram1;
		zephyr,console = &usb_serial;
		zephyr,shell-uart = &usb_serial;
		zephyr,flash = &flash0;
		zephyr,code-partition = &slot0_partition;
		zephyr,bt-hci = &esp32_bt_hci;
		zephyr,display = &lcd0;
	};

	aliases {
		sw0 = &button_key1;
		sw1 = &button_key2;
		imu0 = &bmi270;
		accel0 = &bmi270;
		watchdog0 = &wdt0;
		i2c-0 = &i2c0;
		adc-0 = &m5pm1_adc;
	};

	/*
	 * Two programmable buttons (hardware-verified 2026-05-30, facing the unit):
	 * MIDDLE button = KEY1 (G11), RIGHT button = KEY2 (G12). The LEFT button is
	 * the power key wired to the M5PM1 PMIC (not a host GPIO).
	 */
	gpio_keys {
		compatible = "gpio-keys";

		button_key1: button_0 {
			label = "KEY1"; /* middle button, G11 */
			gpios = <&gpio0 11 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>;
			zephyr,code = <INPUT_KEY_0>;
		};

		button_key2: button_1 {
			label = "KEY2"; /* right button, G12 */
			gpios = <&gpio0 12 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>;
			zephyr,code = <INPUT_KEY_1>;
		};
	};

	/*
	 * AW8737 speaker-amplifier enable. The amp shutdown pin is gated by the
	 * M5PM1 PMIC GPIO3 (PYG3): driving it high un-mutes the speaker path.
	 * Modeled as a plain (driver-less) node carrying an amp-gpios spec that
	 * app/src/audio.c reads via GPIO_DT_SPEC_GET. Deliberately NOT a gpio-leds
	 * / regulator node so nothing enables it at boot; audio.c configures it
	 * output-inactive and drives it high only for the duration of playback
	 * (anti-pop). The MFD gpio child performs masked register writes, so
	 * toggling pin 3 preserves the neighbouring L3B/LCD-rail bit on pin 2.
	 */
	sound_amp: sound-amp {
		compatible = "m5stack,sticks3-amp";
		status = "okay";
		amp-gpios = <&m5pm1_gpio 3 GPIO_ACTIVE_HIGH>;
	};

	/*
	 * LCD/peripheral power rail (L3B). The M5PM1 PMIC gates this domain via
	 * its GPIO2 (PYG2); driving it high powers the LCD/MIC/SPK domain. Modeled
	 * as a regulator-fixed switched by the MFD gpio child (m5pm1_gpio pin 2).
	 * regulator-boot-on enables it at init, before the display; the 100 ms
	 * startup-delay matches the vendor settle time (HW-003 power-before-init).
	 */
	lcd_power: lcd-l3b {
		compatible = "regulator-fixed";
		regulator-name = "lcd-l3b";
		enable-gpios = <&m5pm1_gpio 2 GPIO_ACTIVE_HIGH>;
		regulator-boot-on;
		startup-delay-us = <100000>;
	};

	/*
	 * LCD backlight enable. M5Stack PinMap: BL = G38 (gpio1 pin 6). The vendor
	 * stack drives this via LEDC PWM; for bring-up a fixed on/off switch is
	 * enough. The backlight only lights once the L3B rail (lcd_power) is on.
	 */
	lcd_backlight: lcd-backlight {
		compatible = "regulator-fixed";
		regulator-name = "lcd-backlight";
		enable-gpios = <&gpio1 6 GPIO_ACTIVE_HIGH>;
		regulator-boot-on;
	};

	/*
	 * ST7789P3 LCD on SPI2 via the MIPI-DBI SPI shim.
	 * M5Stack PinMap: MOSI G39, SCK G40 (pinctrl), CS G41, DC/RS G45, RST G21.
	 * Panel geometry/offsets/inversion from the vendor M5GFX StickS3 config.
	 */
	mipi_dbi: mipi-dbi {
		compatible = "zephyr,mipi-dbi-spi";
		spi-dev = <&spi2>;
		dc-gpios = <&gpio1 13 GPIO_ACTIVE_HIGH>;   /* G45 */
		reset-gpios = <&gpio0 21 GPIO_ACTIVE_LOW>; /* G21 */
		write-only;
		#address-cells = <1>;
		#size-cells = <0>;

		lcd0: st7789v@0 {
			compatible = "sitronix,st7789v";
			reg = <0>;
			mipi-max-frequency = <40000000>;
			mipi-mode = "MIPI_DBI_MODE_SPI_4WIRE";

			width = <135>;
			height = <240>;
			x-offset = <52>;
			y-offset = <40>;

			vcom = <0x19>;
			gctrl = <0x35>;
			vrhs = <0x12>;
			vdvs = <0x20>;
			mdac = <0x00>;
			gamma = <0x01>;
			colmod = <0x55>;
			lcm = <0x2c>;
			porch-param = [0c 0c 00 33 33];
			cmd2en-param = [5a 69 02 01];
			pwctrl1-param = [a4 a1];
			pvgam-param = [d0 04 0d 11 13 2b 3f 54 4c 18 0d 0b 1f 23];
			nvgam-param = [d0 04 0c 11 13 2c 3f 44 51 2f 1f 1f 20 23];
			ram-param = [00 e0];
			rgb-param = [40 02 14];
		};
	};
};

&usb_serial {
	status = "okay";
};

&uart0 {
	status = "okay";
	current-speed = <115200>;
	pinctrl-0 = <&uart0_default>;
	pinctrl-names = "default";
};

&i2c0 {
	status = "okay";
	clock-frequency = <I2C_BITRATE_STANDARD>;
	pinctrl-0 = <&i2c0_default>;
	pinctrl-names = "default";

	/* On-board 6-axis IMU. M5Stack PinMap: I2C address 0x68. */
	bmi270: bmi270@68 {
		compatible = "bosch,bmi270";
		reg = <0x68>;
		status = "okay";
	};

	/*
	 * ES8311 mono audio codec (I2C control @ 0x18, I2S audio data on i2s0).
	 * The binding requires only reg; the StickS3 has no discrete codec
	 * reset/enable line (the speaker amp is enabled separately via the
	 * sound_amp node), so no reset-/enable-gpios are added here. The driver
	 * (CONFIG_AUDIO_CODEC_ES8311) only compiles when CONFIG_AUDIO_CODEC is
	 * enabled (overlay-audio.conf), so this node is inert in the default
	 * build even though it is present.
	 */
	es8311: es8311@18 {
		compatible = "everest,es8311";
		reg = <0x18>;
		status = "okay";
	};

	/*
	 * M5PM1 PMIC (0x6e), modeled as a multi-function device (MFD) with a GPIO
	 * controller child and an ADC child, matching upstream Zephyr PR #109961.
	 *  - m5pm1_gpio: the 5 PYG GPIOs. PYG2 gates the LCD/peripheral L3B rail
	 *    (driven by the top-level lcd_power regulator-fixed).
	 *  - m5pm1_adc: power telemetry. Logical channel 1 = VBAT (battery mV).
	 */
	m5pm1: pmic@6e {
		compatible = "m5stack,m5pm1";
		reg = <0x6e>;
		status = "okay";

		m5pm1_gpio: gpio {
			compatible = "m5stack,m5pm1-gpio";
			gpio-controller;
			#gpio-cells = <2>;
			ngpios = <5>;
			status = "okay";
		};

		m5pm1_adc: adc {
			compatible = "m5stack,m5pm1-adc";
			#io-channel-cells = <1>;
			#address-cells = <1>;
			#size-cells = <0>;
			status = "okay";

			/* Channel 1 = VBAT (battery voltage, reported in mV). */
			channel@1 {
				reg = <1>;
				zephyr,gain = "ADC_GAIN_1";
				zephyr,reference = "ADC_REF_INTERNAL";
				zephyr,acquisition-time = <ADC_ACQ_TIME_DEFAULT>;
				zephyr,resolution = <12>;
			};
		};
	};
};

&spi2 {
	#address-cells = <1>;
	#size-cells = <0>;
	status = "okay";
	pinctrl-0 = <&spim2_default>;
	pinctrl-names = "default";
	cs-gpios = <&gpio1 9 GPIO_ACTIVE_LOW>; /* LCD CS = G41 */
};

/*
 * GDMA controller. The esp32-i2s driver hard-requires the GDMA node to be
 * status "okay" (it #errors otherwise) and the i2s0 node references its
 * channels via dmas = <&dma 2>,<&dma 3>. Enabling the controller node here is
 * inert for builds without CONFIG_DMA (the GDMA driver only compiles when
 * CONFIG_DMA=y, which the default build leaves off), so the default image is
 * unchanged; the audio overlay (overlay-audio.conf) turns CONFIG_DMA on.
 */
&dma {
	status = "okay";
};

/*
 * I2S0 carries audio data to/from the ES8311 codec. The SoC dtsi already
 * provides the GDMA channels (dmas/dma-names = "rx","tx"), which the
 * esp32-i2s driver requires; here we only enable the controller and bind the
 * pin group. Pins (M5Stack StickS3, hardware-verified): MCLK G18, BCLK G17,
 * WS/LRCK G15, DSDIN/DOUT (SoC->codec) G14, ASDOUT/DIN (codec->SoC) G16.
 */
&i2s0 {
	status = "okay";
	pinctrl-0 = <&i2s0_default>;
	pinctrl-names = "default";
};

&gpio0 {
	status = "okay";
};

&gpio1 {
	status = "okay";
};

&wdt0 {
	status = "okay";
};

&timer0 {
	status = "okay";
};

&timer1 {
	status = "okay";
};

&esp32_bt_hci {
	status = "okay";
};

&wifi {
	status = "okay";
};
